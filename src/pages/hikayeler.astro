---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../sections/Footer.jsx';
import StickyContactBar from '../components/StickyContactBar.jsx';
import ConsentNotice from '../components/ConsentNotice.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import { getCollection } from 'astro:content';
import { breadcrumbSchema } from '../lib/schema';

const allPosts = await getCollection('blog');
const stories = allPosts
  .filter((p) => p.data.hikaye === true)
  .sort((a, b) => (a.data.title || '').localeCompare(b.data.title || ''));

const schemas = [
  breadcrumbSchema([
    { label: 'Anasayfa', href: '/' },
    { label: 'Saha Hikayeleri' },
  ]),
];
---

<Layout
  title="Saha Hikayeleri — Gerçek IT Olayları ve Dersler"
  description="Türk KOBİ ve orta ölçekli şirketlerde yaşanmış gerçek IT krizlerinden derlenen saha hikayeleri — ransomware, insider risk, network outage, incident response vakaları."
  canonical="/hikayeler/"
  schema={schemas}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6">

        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-8 max-w-5xl mx-auto">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <span class="text-slate-300">Saha Hikayeleri</span>
            </li>
          </ol>
        </nav>

        <!-- Hero -->
        <div class="max-w-4xl mx-auto mb-14 text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-purple-900/30 border border-purple-800/60 text-purple-300 text-sm mb-5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Gerçek IT Vakalarından
          </div>
          <h1 class="text-3xl md:text-5xl font-bold mb-5">
            Saha Hikayeleri
          </h1>
          <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
            Türk KOBİ ve orta ölçekli şirketlerinde yaşanan gerçek IT krizleri — saat saat anlatımı,
            teknik detayları ve çıkarılan dersler. İsimler anonim, deneyim gerçek.
          </p>
        </div>

        <!-- Stories Grid -->
        <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
          {stories.map((story) => (
            <a
              href={`/blog/${story.data.slug || story.id}/`}
              class="group p-6 rounded-2xl bg-slate-900/40 border border-slate-800 hover:border-purple-500/40 transition-all hover:-translate-y-0.5 block"
            >
              <div class="inline-block mb-3 px-2 py-0.5 rounded text-xs font-semibold bg-purple-900/30 text-purple-300 border border-purple-800/60">
                SAHA HİKAYESİ
              </div>
              <h2 class="text-lg md:text-xl font-bold text-white group-hover:text-purple-400 transition-colors mb-3 leading-snug">
                {story.data.title}
              </h2>
              {story.data.meta_description && (
                <p class="text-sm text-slate-400 line-clamp-3 leading-relaxed">
                  {story.data.meta_description}
                </p>
              )}
              <div class="mt-4 text-sm text-purple-400 font-semibold">
                Hikayeyi oku →
              </div>
            </a>
          ))}
        </div>

        <!-- Info -->
        <section class="max-w-3xl mx-auto mt-16">
          <div class="p-8 rounded-2xl bg-slate-900/40 border border-slate-800">
            <h2 class="text-xl font-bold text-white mb-3">Bu Hikayeler Neden Önemli?</h2>
            <p class="text-slate-300 leading-relaxed mb-4">
              Teknik dokümantasyon hatayı anlatır, ama bir krizin <strong class="text-white">nasıl yaşandığını, nasıl karar verildiğini, neyi atladığınızı</strong> anlatmaz. Saha hikayeleri o "sabah saat 6:45'te başka bir dünyada uyanma" deneyimini aktarır.
            </p>
            <p class="text-slate-300 leading-relaxed mb-4">
              Bu sayfa birden fazla gerçek vakadan derlenen anlatılar içerir. Teknik detaylar gerçektir, kurumsal ve kişisel isimler anonimleştirilmiştir. Amaç, sizin şirketinizin bu senaryoları yaşamadan hazırlanması.
            </p>
            <a
              href="/#contact"
              class="inline-block px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-xl font-bold transition-all"
            >
              Kendi Kriz Hazırlığınızı Değerlendirelim
            </a>
          </div>
        </section>

      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
