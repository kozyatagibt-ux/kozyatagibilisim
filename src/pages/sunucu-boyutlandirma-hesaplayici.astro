---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../sections/Footer.jsx';
import StickyContactBar from '../components/StickyContactBar.jsx';
import ConsentNotice from '../components/ConsentNotice.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import ServerSizingCalculator from '../components/ServerSizingCalculator.jsx';
import { breadcrumbSchema } from '../lib/schema';

const schemas = [
  breadcrumbSchema([
    { label: 'Anasayfa', href: '/' },
    { label: 'Sunucu Boyutlandırma Hesaplayıcı' },
  ]),
];
---

<Layout
  title="Sunucu Boyutlandırma Hesaplayıcı — CPU RAM Disk IOPS Önerisi"
  description="Kullanıcı sayısı ve iş yüküne göre doğru sunucu konfigürasyonu. ERP, Active Directory, terminal server, CAD, sanallaştırma senaryoları için CPU/RAM/disk/NIC önerisi ve tahmini maliyet."
  canonical="/sunucu-boyutlandirma-hesaplayici/"
  schema={schemas}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6">

        <nav aria-label="Breadcrumb" class="mb-8 max-w-5xl mx-auto">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <span class="text-slate-300">Sunucu Boyutlandırma</span>
            </li>
          </ol>
        </nav>

        <div class="max-w-3xl mx-auto mb-10 text-center">
          <h1 class="text-3xl md:text-5xl font-bold mb-5">
            Sunucu Boyutlandırma Hesaplayıcı
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed">
            "Kaç çekirdek CPU, ne kadar RAM, hangi disk tipi?" sorusuna iş yükünüze göre somut cevap. ERP, AD, Terminal Server, CAD, sanallaştırma senaryoları için kalibre edilmiş.
          </p>
        </div>

        <ServerSizingCalculator client:load />

        <section class="max-w-3xl mx-auto mt-20 space-y-6">
          <h2 class="text-2xl font-bold">Hesaplama Metodolojisi</h2>
          <div class="text-slate-300 leading-relaxed space-y-4">
            <p>
              Hesaplayıcı; Dell PowerEdge, HPE ProLiant ve Lenovo ThinkSystem resmi sizing guide'ları + 100+ gerçek kurulum verisinin analiziyle kalibre edilmiştir.
            </p>
            <p>
              Her iş yükü tipi için kullanıcı başına tipik CPU ve RAM tüketimi + IOPS ihtiyacı farklıdır:
            </p>
            <ul class="space-y-1 ml-4 text-sm">
              <li>• <strong class="text-white">Dosya paylaşımı</strong>: Düşük CPU, düşük IOPS (4/user) — HDD yeterli olabilir</li>
              <li>• <strong class="text-white">Active Directory + Print</strong>: Hafif kaynak, yüksek uptime ihtiyacı</li>
              <li>• <strong class="text-white">ERP / MSSQL</strong>: Yüksek IOPS (25/user) — SSD şart, çekirdek sayısı kritik</li>
              <li>• <strong class="text-white">Terminal Server</strong>: RAM yoğun (kullanıcı başına 2 GB) + CPU yoğun</li>
              <li>• <strong class="text-white">CAD / Render paylaşımı</strong>: Yüksek IOPS, büyük dosya — NVMe + 10GbE</li>
              <li>• <strong class="text-white">Sanallaştırma Host</strong>: En yüksek kaynak — her VM kendi kullanıcı sayısıyla ölçülmeli</li>
            </ul>
            <p>
              Pik yük çarpanı, normal çalışma saatlerinde yükün kaç katına kadar çıkabileceğini ifade eder. Muhasebe/finans departmanları için ay sonları 2x, ERP raporlama günleri için 2-3x tipiktir.
            </p>
          </div>
        </section>

        <section class="max-w-3xl mx-auto mt-12 text-center">
          <div class="p-8 rounded-3xl bg-gradient-to-br from-blue-950/40 to-cyan-950/20 border border-blue-800/30">
            <h2 class="text-2xl font-bold mb-3">Size Özel Detaylı Teklif</h2>
            <p class="text-slate-400 mb-6">
              Mevcut altyapınızı inceleyip kurumsal tedarikçi anlaşma fiyatlarıyla size özel teklif sunuyoruz. Donanım + lisans + kurulum + 1 yıl bakım tek sözleşmede.
            </p>
            <a
              href="/#contact"
              class="inline-block px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-xl font-bold transition-all"
            >
              Ücretsiz Keşif Görüşmesi
            </a>
          </div>
        </section>

      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
