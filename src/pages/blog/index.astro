---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../sections/Footer.jsx';
import StickyContactBar from '../../components/StickyContactBar.jsx';
import ConsentNotice from '../../components/ConsentNotice.jsx';
import WhatsAppButton from '../../components/WhatsAppButton.jsx';

const blogPosts = await getCollection('blog');
const PILLAR_META: Record<number, { slug: string | null; title: string }> = {
  1: { slug: 'yonetilen-it-hizmetleri', title: 'Yönetilen IT Hizmetleri' },
  2: { slug: 'kobi-siber-guvenlik', title: 'KOBİ Siber Güvenlik' },
  3: { slug: 'sirket-veri-yedekleme', title: 'Şirket Veri Yedekleme' },
  4: { slug: 'kurumsal-network-kurulumu', title: 'Kurumsal Network Kurulumu' },
  5: { slug: null, title: 'Günlük Bilgisayar Sorunları & Çözümleri' },
  6: { slug: null, title: 'E-Posta, Yazıcı & Bağlantı Sorunları' },
  7: { slug: null, title: 'Siber Tehdit & Acil Müdahale Rehberleri' },
  8: { slug: null, title: 'Windows & Office Sorun Çözümleri' },
  9: { slug: null, title: 'Donanım & Cihaz Sorunları' },
};
const grouped = [1, 2, 3, 4, 5, 6, 7, 8, 9].map(p => ({
  pillar: PILLAR_META[p],
  posts: blogPosts.filter(bp => bp.data.pillar === p),
})).filter(g => g.posts.length > 0);
---

<Layout
  title="Blog: KOBİ IT Rehberleri"
  description="Yönetilen IT, siber güvenlik, veri yedekleme ve network konularında KOBİ'ler için pratik rehberler."
  canonical="/blog"
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6 max-w-5xl">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
          <a href="/" class="hover:text-white">Anasayfa</a>
          <span>/</span>
          <span class="text-slate-300">Blog</span>
        </nav>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Blog & Rehberler</h1>
        <p class="text-slate-400 text-lg mb-12 max-w-3xl">
          İstanbul KOBİ'leri için yönetilen IT, siber güvenlik, veri yedekleme ve kurumsal network konularında uygulanabilir rehberler.
        </p>

        {grouped.map(({ pillar, posts }) => (
          <section class="mb-16">
            <div class="flex items-baseline justify-between mb-6">
              <h2 class="text-2xl md:text-3xl font-bold text-white">{pillar.title}</h2>
              {pillar.slug && (
                <a href={`/${pillar.slug}`} class="text-cyan-400 hover:text-cyan-300 text-sm font-medium inline-flex items-center gap-1">
                  Kapsamlı rehberi oku →
                </a>
              )}
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              {posts.map(p => (
                <a
                  href={`/blog/${p.data.slug || p.id}`}
                  class="group block p-6 bg-slate-900/60 border border-slate-800 rounded-2xl hover:border-cyan-500/40 hover:bg-slate-800/60 transition-all"
                >
                  <h3 class="text-lg font-semibold text-white group-hover:text-cyan-300 mb-2">{p.data.title}</h3>
                  <p class="text-sm text-slate-400 line-clamp-2">{p.data.meta_description}</p>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
