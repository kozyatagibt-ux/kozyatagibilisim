---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../sections/Footer.jsx';
import StickyContactBar from '../components/StickyContactBar.jsx';
import ConsentNotice from '../components/ConsentNotice.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import RansomwareRiskQuiz from '../components/RansomwareRiskQuiz.jsx';
import { breadcrumbSchema } from '../lib/schema';

const schemas = [
  breadcrumbSchema([
    { label: 'Anasayfa', href: '/' },
    { label: 'Ransomware Risk Testi' },
  ]),
];
---

<Layout
  title="Ransomware Risk Değerlendirme Testi — Şirketinizin Siber Güvenlik Skoru"
  description="15 soruda şirketinizin ransomware saldırısına karşı hazırlık seviyesini ölçün. Yedekleme, kimlik yönetimi, ağ güvenliği, endpoint ve olay müdahale skoru."
  canonical="/ransomware-risk-testi/"
  schema={schemas}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6">

        <nav aria-label="Breadcrumb" class="mb-8 max-w-3xl mx-auto">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <span class="text-slate-300">Ransomware Risk Testi</span>
            </li>
          </ol>
        </nav>

        <!-- Hero -->
        <div class="max-w-3xl mx-auto mb-10 text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-900/30 border border-red-800/60 text-red-300 text-sm mb-5">
            <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
            15 soru · 3 dakika
          </div>
          <h1 class="text-3xl md:text-5xl font-bold mb-5">
            Ransomware'a Ne Kadar Hazırsınız?
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed">
            Ransomware saldırısına uğrayan Türk KOBİ'lerinin %60'ı yedekleri yetersiz olduğu için ciddi veri kaybı yaşıyor. Bu 15 soruluk değerlendirme ile şirketinizin risk profilini öğrenin — anonim, kayıt gerekmez.
          </p>
        </div>

        <!-- Quiz -->
        <RansomwareRiskQuiz client:load />

        <!-- About -->
        <section class="max-w-3xl mx-auto mt-20">
          <h2 class="text-2xl font-bold mb-5">Bu Test Neye Göre Hazırlandı?</h2>
          <div class="space-y-4 text-slate-300 leading-relaxed">
            <p>
              Skor algoritması; NIST Cybersecurity Framework, CIS Controls ve Microsoft Security Baseline referansları ışığında, 2024-2026 döneminde gerçekleşmiş 200+ ransomware vakasının kök sebep analizine dayanır.
            </p>
            <p>
              Her kategori (yedekleme, kimlik, ağ, endpoint, e-posta, insan faktörü, olay müdahale) ransomware başarı oranını gerçekten etkileyen temel kontrolleri ölçer.
            </p>
            <p class="text-sm text-slate-400 bg-slate-900/40 rounded-xl p-4 border border-slate-800">
              <strong class="text-white">Uyarı:</strong> Bu test genel bir öz-değerlendirme aracıdır. Gerçek bir güvenlik denetimi ya da pentest yerini tutmaz. Sonuçlarınız "iyi" çıksa dahi profesyonel bir değerlendirme önerilir.
            </p>
          </div>
        </section>

        <!-- CTA -->
        <section class="max-w-3xl mx-auto mt-16 text-center">
          <div class="p-8 rounded-3xl bg-gradient-to-br from-blue-950/40 to-cyan-950/20 border border-blue-800/30">
            <h2 class="text-2xl font-bold mb-3">Skorunuz "Orta" veya "Düşük" Çıktıysa</h2>
            <p class="text-slate-400 mb-6">
              Kozyatağı Bilişim olarak ransomware dayanıklılık değerlendirmesi + remediation paketimizle ücretsiz başlangıç görüşmesi sunuyoruz. Hangi alanları önce güçlendirmeniz gerektiğini birlikte planlayalım.
            </p>
            <a
              href="/#contact"
              class="inline-block px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-xl font-bold transition-all"
            >
              Ücretsiz Risk Değerlendirmesi Talep Et
            </a>
          </div>
        </section>

      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
