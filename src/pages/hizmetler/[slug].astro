---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../sections/Footer.jsx';
import StickyContactBar from '../../components/StickyContactBar.jsx';
import ConsentNotice from '../../components/ConsentNotice.jsx';
import WhatsAppButton from '../../components/WhatsAppButton.jsx';
import { services, getService } from '../../data/services';
import { serviceSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';

const PILLAR_META: Record<string, string> = {
  'yonetilen-it-hizmetleri': 'Yönetilen IT Hizmetleri',
  'kobi-siber-guvenlik': 'KOBİ Siber Güvenlik',
  'sirket-veri-yedekleme': 'Şirket Veri Yedekleme',
  'kurumsal-network-kurulumu': 'Kurumsal Network Kurulumu',
};

export function getStaticPaths() {
  return services.map((s) => ({
    params: { slug: s.slug },
    props: { service: s },
  }));
}

const { service } = Astro.props;

const pillarTitle = PILLAR_META[service.pillarLink] || '';
const relatedSvcs = (service.relatedServices || []).map((slug: string) => services.find((sv) => sv.slug === slug)).filter(Boolean);

const schemas = [
  serviceSchema({
    name: service.title,
    description: service.meta,
    url: `https://kozyatagibilisim.com/hizmetler/${service.slug}`,
  }),
  breadcrumbSchema([
    { label: 'Anasayfa', href: '/' },
    { label: 'Hizmetler', href: '/hizmetler' },
    { label: service.title },
  ]),
];
if (service.faqs?.length) schemas.push(faqSchema(service.faqs));
---

<Layout
  title={service.title}
  description={service.meta}
  canonical={`/hizmetler/${service.slug}`}
  schema={schemas}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6 max-w-5xl">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <a href="/hizmetler" class="hover:text-cyan-400 transition-colors">Hizmetler</a>
            </li>
            <li class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <span class="text-slate-300">{service.title}</span>
            </li>
          </ol>
        </nav>

        <!-- Hero -->
        <header class="mb-10 flex flex-col md:flex-row items-start gap-6">
          <div class="bg-slate-800/60 w-20 h-20 rounded-2xl flex items-center justify-center border border-slate-700 flex-shrink-0">
            <svg class="w-10 h-10 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-3">{service.title}</h1>
            <p class="text-lg md:text-xl text-slate-400">{service.tagline}</p>
            <a
              href="/#contact"
              class="mt-4 inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold shadow-lg shadow-blue-500/20 transition-all hover:-translate-y-0.5"
            >
              Ücretsiz Keşif Al
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </header>

        <!-- Intro -->
        <div class="prose prose-invert max-w-none mb-12">
          <p class="text-slate-300 text-lg leading-relaxed">{service.intro}</p>
        </div>

        <!-- Bu Hizmet Kimin İçin? -->
        {service.idealFor && service.idealFor.length > 0 && (
          <section class="mb-12">
            <div class="flex items-center gap-3 mb-6">
              <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <h2 class="text-2xl font-bold text-white">Bu Hizmet Kimin İçin?</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              {service.idealFor.map((item: string) => (
                <div class="flex items-start gap-3 p-4 bg-slate-900/40 border border-slate-800 rounded-xl">
                  <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <span class="text-slate-300">{item}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Nelerin Dahil? -->
        <section class="mb-12">
          <div class="flex items-center gap-3 mb-6">
            <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <h2 class="text-2xl font-bold text-white">Nelerin Dahil?</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {service.features.map((f: { title: string; desc: string }) => (
              <div class="p-6 bg-slate-900/60 border border-slate-800 rounded-2xl">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <div>
                    <h3 class="text-lg font-semibold text-white mb-1">{f.title}</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">{f.desc}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Nasıl Çalışır? -->
        {service.process && service.process.length > 0 && (
          <section class="mb-12">
            <div class="flex items-center gap-3 mb-6">
              <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <h2 class="text-2xl font-bold text-white">Nasıl Çalışır?</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
              {service.process.map((p: { step: number; title: string; desc: string }) => (
                <div class="relative p-6 bg-slate-900/60 border border-slate-800 rounded-2xl">
                  <div class="w-10 h-10 rounded-full bg-cyan-500/15 border border-cyan-500/30 flex items-center justify-center text-cyan-400 font-bold text-lg mb-4">
                    {p.step}
                  </div>
                  <h3 class="text-lg font-semibold text-white mb-2">{p.title}</h3>
                  <p class="text-slate-400 text-sm leading-relaxed">{p.desc}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- CTA -->
        <div class="my-10 rounded-3xl bg-gradient-to-br from-blue-900/40 to-cyan-900/30 border border-cyan-700/40 p-8 md:p-10 shadow-xl shadow-cyan-900/10">
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">{service.title} için ücretsiz keşif</h3>
          <p class="text-slate-300 mb-6 leading-relaxed">Mevcut durumunuzu değerlendirip, ihtiyaçlarınıza özel çözüm ve fiyat teklifi sunalım.</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="/#contact"
              class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold shadow-lg shadow-blue-500/20 transition-all hover:-translate-y-0.5"
            >
              Ücretsiz Keşif Talep Et
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <span
              class="inline-flex items-center gap-2 bg-slate-800 text-white px-6 py-3 rounded-xl font-semibold border border-slate-700 whitespace-nowrap cursor-text"
            >
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              0541 636 77 75
            </span>
          </div>
        </div>

        <!-- SSS Accordion -->
        {service.faqs && service.faqs.length > 0 && (
          <section class="mt-12 mb-12">
            <div class="flex items-center gap-3 mb-6">
              <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <h2 class="text-2xl font-bold text-white">Sıkça Sorulan Sorular</h2>
            </div>
            <div class="space-y-3" id="faq-accordion">
              {service.faqs.map((faq: { q: string; a: string }, i: number) => (
                <div class="border border-slate-800 rounded-xl overflow-hidden" data-faq-item>
                  <button
                    class="w-full flex items-center justify-between p-5 text-left bg-slate-900/60 hover:bg-slate-800/60 transition-colors"
                    data-faq-trigger
                    aria-expanded="false"
                  >
                    <span class="text-white font-medium pr-4">{faq.q}</span>
                    <svg class="w-5 h-5 text-slate-400 flex-shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </button>
                  <div class="px-5 pb-5 bg-slate-900/40 hidden" data-faq-content>
                    <p class="text-slate-400 leading-relaxed">{faq.a}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- İlgili Hizmetler -->
        {relatedSvcs.length > 0 && (
          <section class="mt-12 mb-12">
            <div class="flex items-center gap-3 mb-6">
              <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              <h2 class="text-2xl font-bold text-white">İlgili Hizmetler</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
              {relatedSvcs.map((rs: any) => (
                <a
                  href={`/hizmetler/${rs.slug}`}
                  class="group flex items-center gap-4 p-5 bg-slate-900/60 border border-slate-800 rounded-2xl hover:border-cyan-500/40 transition-all"
                >
                  <div class="bg-slate-800/60 w-12 h-12 rounded-xl flex items-center justify-center border border-slate-700 flex-shrink-0 group-hover:border-cyan-500/30">
                    <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-white group-hover:text-cyan-300">{rs.title}</h3>
                    <p class="text-sm text-slate-500">{rs.tagline}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Kapsamlı Rehber -->
        {service.pillarLink && (
          <section class="mt-10 p-6 bg-slate-900/40 border border-slate-800 rounded-2xl">
            <p class="text-sm text-slate-400 mb-2">Kapsamlı rehber:</p>
            <a href={`/${service.pillarLink}`} class="text-xl font-semibold text-cyan-400 hover:text-cyan-300">
              {pillarTitle} &rarr;
            </a>
          </section>
        )}

        <!-- İlgili Yazılar -->
        {service.relatedClusters && service.relatedClusters.length > 0 && (
          <section class="mt-12">
            <h2 class="text-2xl font-bold text-white mb-6">İlgili Yazılar</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
              {service.relatedClusters.map((clusterSlug: string) => (
                <a
                  href={`/blog/${clusterSlug}`}
                  class="group block p-5 bg-slate-900/60 border border-slate-800 rounded-2xl hover:border-cyan-500/40 transition-all"
                >
                  <h3 class="font-semibold text-white group-hover:text-cyan-300 mb-2">
                    {clusterSlug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}
                  </h3>
                  <span class="inline-flex items-center gap-1 text-cyan-400 text-sm">
                    Oku
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </span>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Alt CTA -->
        <section class="mt-16 text-center p-10 bg-gradient-to-br from-blue-950/40 to-slate-900/40 border border-slate-800 rounded-3xl">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
            {service.title} hakkında konuşalım
          </h2>
          <p class="text-slate-400 mb-6 max-w-xl mx-auto">
            30 dakikalık ücretsiz keşif görüşmesinde mevcut durumunuzu analiz edelim, size özel çözüm önerelim.
          </p>
          <a
            href="/#contact"
            class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-bold shadow-lg shadow-blue-500/20 transition-all hover:-translate-y-0.5"
          >
            Ücretsiz Keşif Planla
            <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </section>
      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>

<script>
  document.querySelectorAll('[data-faq-trigger]').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('[data-faq-item]');
      const content = item.querySelector('[data-faq-content]');
      const icon = btn.querySelector('svg');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        content.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        icon.style.transform = '';
      } else {
        content.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
