---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../sections/Footer.jsx';
import StickyContactBar from '../components/StickyContactBar.jsx';
import ConsentNotice from '../components/ConsentNotice.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import ITCostCalculator from '../components/ITCostCalculator.jsx';
import { breadcrumbSchema, faqSchema } from '../lib/schema';

const faqs = [
  {
    q: 'Bu hesaplayıcı ne kadar doğru sonuç verir?',
    a: '2024-2025 Türkiye piyasa ortalamalarına göre kalibre edilmiştir. Tedarikçi pazarlığı, mevcut lisans/donanım envanteri ve özel ihtiyaçlara göre gerçek teklif ±%20 değişebilir. Detaylı öneri için ücretsiz keşif görüşmesi gerekir.',
  },
  {
    q: 'Hesaplayıcıda neden sadece Fortinet, Sophos ve Palo Alto var?',
    a: 'Türkiye\'de 50-200 kişilik şirket segmentinde en çok tercih edilen üç markadır. Cisco, Check Point gibi alternatifler de mevcut ancak orta ölçek için fiyat/performans açısından bu üç marka daha dengeli.',
  },
  {
    q: 'Yönetilen IT (MSP) ile kendi bordrolu IT personeli maliyeti karşılaştırması yapabilir miyim?',
    a: 'Yönetilen IT paketi bu hesaplayıcıda standart olarak dahildir. Bordrolu IT personeli karşılaştırması için "MSP mi Kendi IT Personeli mi" blog yazımızda detaylı TCO analizi bulabilirsiniz.',
  },
  {
    q: 'ISO 27001 uyum maliyeti neden bu kadar yüksek?',
    a: 'İlk yıl maliyetine danışmanlık, dokümantasyon hazırlama, gerekli teknik araçlar (SIEM, vulnerability scanner), sertifikasyon firması ücretleri ve iç mesai dahildir. 2. yıldan itibaren yıllık sürdürme maliyeti 80-150 bin TL bandına düşer.',
  },
  {
    q: 'Küçük bir sunucu mu yoksa tam buluta geçmek mi daha ekonomik?',
    a: 'Genellikle 30-80 kişi aralığında "tam bulut" ekonomik; 80+ kişi ve özel yazılım (ERP, CAD) varsa yerel sunucu hâlâ daha verimli. 5 yıllık TCO karşılaştırması için keşif görüşmesinde sizin senaryonuza özel hesap çıkarıyoruz.',
  },
  {
    q: 'Hesaplayıcı neden e-ticaret sunucusu, VPN, video konferans donanımı gibi özel kalemleri sormuyor?',
    a: 'Genel bir yıllık IT bütçesi tahmini için kalibre edildi. Sektöre özel (üretim OT/IT, e-ticaret, sağlık) veya özel donanım (konferans odası AV) ihtiyaçları keşif sürecinde ayrı değerlendirilir.',
  },
];

const schemas = [
  breadcrumbSchema([
    { label: 'Anasayfa', href: '/' },
    { label: 'IT Maliyet Hesaplayıcı' },
  ]),
  faqSchema(faqs),
];
---

<Layout
  title="IT Maliyet Hesaplayıcı — 50-250 Kişilik Şirket Yıllık Bütçe Tahmini"
  description="50-250 kişilik Türk şirketi için tahmini yıllık IT bütçesi hesaplayıcısı. Firewall, sunucu, yedekleme, yönetilen IT, EDR, ISO 27001 uyum maliyetleri dahil."
  canonical="/it-maliyet-hesaplayici"
  schema={schemas}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6">

        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-8 max-w-5xl mx-auto">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <span class="text-slate-300">IT Maliyet Hesaplayıcı</span>
            </li>
          </ol>
        </nav>

        <!-- Hero -->
        <div class="max-w-4xl mx-auto mb-12 text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-900/30 border border-cyan-800/60 text-cyan-300 text-sm mb-5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
            2024-2025 Piyasa Verilerine Göre
          </div>
          <h1 class="text-3xl md:text-5xl font-bold mb-5">
            Şirketinizin Yıllık IT Bütçesi Ne Kadar?
          </h1>
          <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
            50-250 kişilik şirketler için tahmini yıllık IT maliyetini 30 saniyede hesaplayın.
            Lisans, sunucu, firewall, yedekleme, yönetilen IT ve uyum maliyetleri dahil.
          </p>
        </div>

        <!-- Calculator -->
        <ITCostCalculator client:load />

        <!-- Context / How to Interpret -->
        <section class="max-w-4xl mx-auto mt-20">
          <h2 class="text-2xl md:text-3xl font-bold mb-6">Sonuçları Nasıl Yorumlamalı?</h2>
          <div class="space-y-4 text-slate-300 leading-relaxed">
            <p>
              Hesaplayıcı size <strong class="text-white">kullanıcı başına aylık IT maliyeti</strong> verir.
              Türk orta ölçekli şirketleri için tipik değerler şu aralıktadır:
            </p>
            <ul class="space-y-2 ml-4">
              <li class="flex items-start gap-3">
                <span class="text-cyan-400 mt-1">•</span>
                <span><strong class="text-white">Minimal senaryo:</strong> 800-1.200 TL / kullanıcı / ay</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-cyan-400 mt-1">•</span>
                <span><strong class="text-white">Standart senaryo:</strong> 1.400-2.000 TL / kullanıcı / ay</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-cyan-400 mt-1">•</span>
                <span><strong class="text-white">Yüksek güvenlik + compliance:</strong> 2.200-3.500 TL / kullanıcı / ay</span>
              </li>
            </ul>
            <p>
              Eğer şu an ödediğiniz kişi başına maliyet minimal aralığının çok altındaysa, genellikle yedekleme, güvenlik izleme veya compliance tarafında boşluk vardır. Tam tersine yüksek senaryoyu aşıyorsanız, optimize edilebilecek alanlar mevcuttur.
            </p>
          </div>
        </section>

        <!-- FAQs -->
        <section class="max-w-3xl mx-auto mt-20">
          <h2 class="text-2xl md:text-3xl font-bold mb-8">Sıkça Sorulan Sorular</h2>
          <div class="space-y-4">
            {faqs.map((faq) => (
              <div class="p-5 rounded-2xl bg-slate-900/40 border border-slate-800/60">
                <h3 class="text-lg font-semibold text-cyan-400 mb-2">{faq.q}</h3>
                <p class="text-slate-300 leading-relaxed">{faq.a}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- CTA -->
        <section class="max-w-3xl mx-auto mt-20 text-center">
          <div class="p-10 rounded-3xl bg-gradient-to-br from-blue-950/40 to-cyan-950/20 border border-blue-800/30">
            <h2 class="text-2xl md:text-3xl font-bold mb-4">Size Özel Detaylı Teklif</h2>
            <p class="text-slate-400 mb-8">
              30 dakikalık ücretsiz keşif görüşmesinde mevcut envanterinizi inceleyip tahminden %95+ doğrulukta özel fiyat teklifi sunuyoruz.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="/#contact"
                class="px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-xl font-bold shadow-[0_4px_20px_rgba(79,70,229,0.4)] transition-all hover:-translate-y-0.5"
              >
                Ücretsiz Keşif Al
              </a>
              <a
                href="tel:+905416367775"
                class="px-8 py-4 bg-slate-800 hover:bg-slate-700 text-white rounded-xl font-bold border border-slate-700 transition-all"
              >
                0541 636 77 75
              </a>
            </div>
          </div>
        </section>

      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
