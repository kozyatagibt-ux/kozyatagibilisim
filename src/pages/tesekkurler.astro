---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../sections/Footer.jsx';
import StickyContactBar from '../components/StickyContactBar.jsx';
import ConsentNotice from '../components/ConsentNotice.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
---

<Layout
  title="Teşekkürler"
  description="Mesajınız bize ulaştı. En kısa sürede dönüş yapacağız."
  canonical="/tesekkurler"
  noindex={true}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6 max-w-5xl">
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-20 h-20 bg-cyan-900/30 border border-cyan-700 rounded-full mb-6">
            <svg class="w-10 h-10 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Teşekkürler!</h1>
          <p class="text-lg text-slate-400 mb-2 max-w-xl mx-auto">
            Mesajınız bize ulaştı. Ekibimiz en kısa sürede (genellikle aynı iş günü içinde) sizinle iletişime geçecek.
          </p>
          <p class="text-sm text-slate-500 mb-10">
            Acil bir durumdaysanız bizi doğrudan <a href="tel:+905416367775" class="text-cyan-400 hover:text-cyan-300">0541 636 77 75</a> numarasından arayabilirsiniz.
          </p>

          <div class="max-w-2xl mx-auto p-6 bg-slate-900/60 border border-slate-800 rounded-2xl mb-10 text-left">
            <h2 class="text-xl font-semibold text-white mb-3">Bekleme süresinde okuyabileceğiniz rehberler</h2>
            <ul class="space-y-2 text-slate-300">
              <li>
                <a href="/yonetilen-it-hizmetleri" class="text-cyan-400 hover:text-cyan-300 inline-flex items-center gap-1">
                  Yönetilen IT Hizmetleri Nedir?
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </li>
              <li>
                <a href="/kobi-siber-guvenlik" class="text-cyan-400 hover:text-cyan-300 inline-flex items-center gap-1">
                  KOBİ Siber Güvenlik Rehberi
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </li>
              <li>
                <a href="/blog" class="text-cyan-400 hover:text-cyan-300 inline-flex items-center gap-1">
                  Tüm Blog Yazıları
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </li>
            </ul>
          </div>

          <a href="/" class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold">
            Anasayfaya Dön
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
