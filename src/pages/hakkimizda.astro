---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../sections/Footer.jsx';
import StickyContactBar from '../components/StickyContactBar.jsx';
import ConsentNotice from '../components/ConsentNotice.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import { breadcrumbSchema } from '../lib/schema';

const values = [
  { title: 'Proaktif Yaklaşım', desc: 'Sorunlar ortaya çıkmadan tespit edilir ve engellenir. 7/24 izleme, otomatik uyarı sistemleri.', icon: 'shield' },
  { title: 'Tek Muhatap', desc: 'Sunucudan e-postaya tüm IT için tek telefon. Suçu başkasına atma yok, çözüm odaklı tek ekip.', icon: 'users' },
  { title: 'SLA Garantili', desc: 'Yanıt süreleri sözleşmede yazılı. Mesai içi 30 dk, kritik durumlarda 15 dk garanti.', icon: 'clock' },
  { title: 'KVKK & 5651 Uyumu', desc: 'Yasal yükümlülüklerinizi karşılayan altyapı, log yönetimi ve raporlama standart.', icon: 'award' },
];
---

<Layout
  title="Hakkımızda"
  description="Kozyatağı Bilişim — İstanbul merkezli kurumsal IT hizmet sağlayıcısı. KOBİ ve orta ölçekli işletmelere yönetilen IT, siber güvenlik ve veri yedekleme çözümleri."
  canonical="/hakkimizda"
  schema={[
    breadcrumbSchema([{ label: 'Anasayfa', href: '/' }, { label: 'Hakkımızda' }]),
  ]}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6 max-w-5xl">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <span class="text-slate-300">Hakkımızda</span>
            </li>
          </ol>
        </nav>

        <header class="mb-12">
          <h1 class="text-4xl md:text-6xl font-bold mb-4">Hakkımızda</h1>
          <p class="text-lg md:text-xl text-slate-400 max-w-3xl">
            İstanbul merkezli, KOBİ ve orta ölçekli işletmelere yönetilen IT hizmetleri sunan bir teknoloji ortağıyız.
          </p>
        </header>

        <section class="prose prose-invert max-w-none mb-12">
          <p class="text-slate-300 text-lg leading-relaxed mb-6">
            Kozyatağı Bilişim, İstanbul Anadolu Yakası'nda kurulu, KOBİ ve orta ölçekli işletmelerin tüm IT altyapı ihtiyaçlarını
            tek çatı altında karşılamak üzere kurulmuş bir kurumsal bilişim hizmet sağlayıcısıdır. Sunucudan ağa, e-postadan
            siber güvenliğe, veri yedeklemeden uzaktan çalışan altyapısına kadar şirketinizin ihtiyaç duyduğu her IT bileşenini
            proaktif olarak yönetiyoruz.
          </p>
          <p class="text-slate-300 text-lg leading-relaxed mb-6">
            Felsefemiz basit: <strong class="text-white">IT bir gider kalemi değil, iş sürekliliği yatırımıdır.</strong>
            Geleneksel "bir sorun çıktığında ararsınız" modeli yerine, sorunlar ortaya çıkmadan önce engellenen, tahmin edilebilir
            aylık maliyetli, SLA garantili bir yönetilen IT modeli sunuyoruz. Müşterilerimiz IT konusunda düşünmek yerine kendi
            işlerini büyütmeye odaklanıyor.
          </p>
          <p class="text-slate-300 text-lg leading-relaxed">
            Sektör fark etmeksizin 10-200 çalışanlı işletmelere hizmet veriyoruz: üretim firmaları, danışmanlık şirketleri,
            muhasebe büroları, lojistik firmaları, sağlık kuruluşları ve teknoloji şirketleri. Aynı yaklaşım, aynı uzmanlık,
            aynı taahhüt — şirketinize özel ölçeklenmiş çözümlerle.
          </p>
        </section>

        <!-- Values grid -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-12">
          {values.map((f) => (
            <div class="p-6 bg-slate-900/60 border border-slate-800 rounded-2xl">
              <div class="flex items-start gap-4">
                <div class="bg-cyan-900/30 w-12 h-12 rounded-xl flex items-center justify-center border border-cyan-800 flex-shrink-0">
                  {f.icon === 'shield' && (
                    <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  )}
                  {f.icon === 'users' && (
                    <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                  )}
                  {f.icon === 'clock' && (
                    <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  )}
                  {f.icon === 'award' && (
                    <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                  )}
                </div>
                <div>
                  <h2 class="text-xl font-semibold text-white mb-2">{f.title}</h2>
                  <p class="text-slate-400 leading-relaxed">{f.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </section>

        <!-- Konum & İletişim -->
        <section class="mb-12 p-8 bg-slate-900/40 border border-slate-800 rounded-2xl">
          <h2 class="text-2xl font-bold text-white mb-4">Konum & İletişim</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-slate-300">
            <div>
              <p class="text-sm text-slate-500 mb-1">Adres</p>
              <p>Quick Tower, İçerenköy E-5 Yanyolu, Umut Sk. No:8, Ataşehir/İstanbul</p>
            </div>
            <div>
              <p class="text-sm text-slate-500 mb-1">Telefon</p>
              <a href="tel:+905416367775" class="hover:text-cyan-400">0541 636 77 75</a>
            </div>
            <div>
              <p class="text-sm text-slate-500 mb-1">E-posta</p>
              <a href="mailto:destek@kozyatagibilisim.com" class="hover:text-cyan-400">destek@kozyatagibilisim.com</a>
            </div>
            <div>
              <p class="text-sm text-slate-500 mb-1">Hizmet Bölgesi</p>
              <p>İstanbul (her iki yaka) + Türkiye geneli uzaktan</p>
            </div>
          </div>
        </section>

        <!-- CTA -->
        <div class="my-10 rounded-3xl bg-gradient-to-br from-blue-900/40 to-cyan-900/30 border border-cyan-700/40 p-8 md:p-10 shadow-xl shadow-cyan-900/10">
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">Tanışmak ister misiniz?</h3>
          <p class="text-slate-300 mb-6 leading-relaxed">Ofisimizde yüz yüze ya da görüntülü 30 dakikalık ücretsiz ön görüşme planlayalım. Mevcut altyapınızı dinleyelim, somut öneriler sunalım.</p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="/#contact"
              class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold shadow-lg shadow-blue-500/20 transition-all hover:-translate-y-0.5"
            >
              Ücretsiz Keşif Talep Et
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <span
              class="inline-flex items-center gap-2 bg-slate-800 text-white px-6 py-3 rounded-xl font-semibold border border-slate-700 whitespace-nowrap cursor-text"
            >
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              0541 636 77 75
            </span>
          </div>
        </div>

        <!-- Hizmet Alanları -->
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-white mb-5">Hizmet Alanlarımız</h2>
          <div class="flex flex-wrap gap-3">
            <a href="/hizmetler" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 rounded-xl text-slate-200 border border-slate-700">Tüm Hizmetler &rarr;</a>
            <a href="/yonetilen-it-hizmetleri" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 rounded-xl text-slate-200 border border-slate-700">Yönetilen IT</a>
            <a href="/kobi-siber-guvenlik" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 rounded-xl text-slate-200 border border-slate-700">Siber Güvenlik</a>
            <a href="/sirket-veri-yedekleme" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 rounded-xl text-slate-200 border border-slate-700">Veri Yedekleme</a>
            <a href="/kurumsal-network-kurulumu" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 rounded-xl text-slate-200 border border-slate-700">Network Kurulumu</a>
          </div>
        </section>
      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
