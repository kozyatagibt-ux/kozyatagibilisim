---
/**
 * Unified dynamic route for:
 * - 4 pillar pages (from content/pillars collection)
 * - 3 local landing pages (from data/locals.js)
 *
 * Static routes like /hakkimizda, /sss, /tesekkurler take priority over this.
 */
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../sections/Footer.jsx';
import StickyContactBar from '../components/StickyContactBar.jsx';
import ConsentNotice from '../components/ConsentNotice.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import { localLandings } from '../data/locals';
import { services } from '../data/services';
import { articleSchema, breadcrumbSchema, localBusinessSchema } from '../lib/schema';

export async function getStaticPaths() {
  const PILLAR_META: Record<number, { slug: string; title: string }> = {
    1: { slug: 'yonetilen-it-hizmetleri', title: 'Yönetilen IT Hizmetleri' },
    2: { slug: 'kobi-siber-guvenlik', title: 'KOBİ Siber Güvenlik' },
    3: { slug: 'sirket-veri-yedekleme', title: 'Şirket Veri Yedekleme' },
    4: { slug: 'kurumsal-network-kurulumu', title: 'Kurumsal Network Kurulumu' },
  };

  const pillars = await getCollection('pillars');
  const allPosts = await getCollection('blog');

  const pillarPaths = pillars.map(p => {
    const pillarSlug = p.data.slug || p.id;
    const meta = PILLAR_META[p.data.pillar as number] || { slug: pillarSlug, title: p.data.title };
    const clusters = allPosts.filter(bp => bp.data.pillar === p.data.pillar);
    return {
      params: { slug: pillarSlug },
      props: { type: 'pillar', entry: p, meta, clusters, local: null },
    };
  });

  const localPaths = localLandings.map(l => ({
    params: { slug: l.slug },
    props: { type: 'local', entry: null, meta: null, clusters: [], local: l },
  }));

  return [...pillarPaths, ...localPaths];
}

const { type, entry, meta, clusters, local } = Astro.props;

// For pillar pages, render the markdown content
let Content: any = null;
if (type === 'pillar' && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

// Compute layout props based on type
const layoutTitle = type === 'pillar' ? entry.data.title : local.title;
const layoutDescription = type === 'pillar' ? entry.data.meta_description : local.meta;
const layoutCanonical = type === 'pillar' ? `/${entry.data.slug || entry.id}` : `/${local.slug}`;
const layoutOgType = type === 'pillar' ? 'article' : 'website';

const layoutSchema = type === 'pillar'
  ? [
      articleSchema({
        title: entry.data.title,
        description: entry.data.meta_description,
        url: `https://kozyatagibilisim.com/${entry.data.slug || entry.id}`,
      }),
      breadcrumbSchema([
        { label: 'Anasayfa', href: '/' },
        { label: 'Rehberler', href: '/blog' },
        { label: meta.title },
      ]),
    ]
  : [
      localBusinessSchema(local.area),
      breadcrumbSchema([{ label: 'Anasayfa', href: '/' }, { label: local.title }]),
    ];
---

<Layout
  title={layoutTitle}
  description={layoutDescription}
  canonical={layoutCanonical}
  ogType={layoutOgType}
  schema={layoutSchema}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6 max-w-5xl">

        {type === 'pillar' && (
          <>
            <!-- Breadcrumb -->
            <nav aria-label="Breadcrumb" class="mb-6">
              <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
                <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
                <li class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  <a href="/blog" class="hover:text-cyan-400 transition-colors">Rehberler</a>
                </li>
                <li class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  <span class="text-slate-300">{meta.title}</span>
                </li>
              </ol>
            </nav>

            <header class="mb-10">
              <div class="inline-block px-3 py-1 rounded-full bg-cyan-900/30 text-cyan-400 text-xs font-semibold mb-4 border border-cyan-800 uppercase tracking-wider">
                Kapsamlı Rehber
              </div>
              <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-4">{entry.data.title}</h1>
              {entry.data.meta_description && (
                <p class="text-lg md:text-xl text-slate-400 max-w-3xl">{entry.data.meta_description}</p>
              )}
            </header>

            <!-- Main content -->
            <article class="prose prose-invert prose-lg max-w-none prose-headings:text-white prose-a:text-cyan-400 prose-strong:text-white prose-code:text-cyan-300 mb-12">
              <Content />
            </article>

            <!-- Inline CTA -->
            <div class="my-10 rounded-3xl bg-gradient-to-br from-blue-900/40 to-cyan-900/30 border border-cyan-700/40 p-8 md:p-10 shadow-xl shadow-cyan-900/10">
              <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">Bu rehberi şirketinizde uygulamak ister misiniz?</h3>
              <p class="text-slate-300 mb-6 leading-relaxed">{meta.title} alanında ücretsiz değerlendirme görüşmesi yapalım. Mevcut altyapınızı analiz edip somut bir yol haritası önerelim.</p>
              <div class="flex flex-col sm:flex-row gap-3">
                <a
                  href="/#contact"
                  class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold shadow-lg shadow-blue-500/20 transition-all hover:-translate-y-0.5"
                >
                  Ücretsiz Keşif Talep Et
                  <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <span
                  class="inline-flex items-center gap-2 bg-slate-800 text-white px-6 py-3 rounded-xl font-semibold border border-slate-700 whitespace-nowrap cursor-text"
                >
                  <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  0541 636 77 75
                </span>
              </div>
            </div>

            <!-- Related blog posts for this pillar -->
            {clusters.length > 0 && (
              <section class="my-12">
                <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">Bu Konudaki Tüm Rehberler</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  {clusters.map((c: any) => (
                    <a
                      href={`/blog/${c.data.slug || c.slug}`}
                      class="group block p-6 bg-slate-900/60 border border-slate-800 rounded-2xl hover:border-cyan-500/40 hover:bg-slate-800/60 transition-all"
                    >
                      <h3 class="text-lg font-semibold text-white group-hover:text-cyan-300 mb-2">{c.data.title}</h3>
                      <p class="text-sm text-slate-400 line-clamp-2 mb-3">{c.data.meta_description}</p>
                      <span class="inline-flex items-center gap-1 text-cyan-400 text-sm font-medium">
                        Devamını oku
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                      </span>
                    </a>
                  ))}
                </div>
              </section>
            )}
          </>
        )}

        {type === 'local' && (
          <>
            <!-- Breadcrumb -->
            <nav aria-label="Breadcrumb" class="mb-6">
              <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
                <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
                <li class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  <span class="text-slate-300">{local.title}</span>
                </li>
              </ol>
            </nav>

            <!-- Hero -->
            <header class="mb-8 flex items-start gap-4">
              <div class="bg-cyan-900/30 w-14 h-14 rounded-xl flex items-center justify-center border border-cyan-800 flex-shrink-0">
                <svg class="w-7 h-7 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight">{local.h1}</h1>
              </div>
            </header>

            <p class="text-lg text-slate-300 leading-relaxed mb-10">{local.intro}</p>

            <!-- Neden Kozyatağı Bilişim -->
            <section class="mb-12">
              <h2 class="text-2xl font-bold text-white mb-5">Neden Kozyatağı Bilişim?</h2>
              <ul class="space-y-3">
                {local.bullets.map((b: string) => (
                  <li class="flex items-start gap-3 text-slate-300">
                    <svg class="w-5 h-5 text-cyan-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </section>

            <!-- Sunduğumuz Hizmetler -->
            <section class="mb-12">
              <h2 class="text-2xl font-bold text-white mb-5">{local.area}'da Sunduğumuz Hizmetler</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {services.map((s) => (
                  <a
                    href={`/hizmetler/${s.slug}`}
                    class="p-5 bg-slate-900/60 border border-slate-800 rounded-xl hover:border-cyan-500/40 transition-all"
                  >
                    <h3 class="text-white font-semibold mb-1">{s.title}</h3>
                    <p class="text-sm text-slate-400">{s.tagline}</p>
                  </a>
                ))}
              </div>
            </section>

            <!-- Detaylı Hizmet Açıklamaları -->
            <section class="mb-16">
              <h2 class="text-3xl font-bold text-white mb-8">{local.area} Bölgesinde IT Hizmetlerimiz — Detaylı</h2>

              <div class="space-y-8">
                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} Sunucu Yönetimi ve Sanallaştırma</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area} bölgesindeki işletmelere sunucu yönetimi hizmeti veriyoruz. Fiziksel sunucu kurulumu, VMware ve Proxmox ile sanallaştırma, yüksek erişilebilirlik (HA) yapılandırması ve 7/24 sunucu izleme hizmetlerimizle {local.area}'daki şirketlerin sunucu altyapısını kesintisiz yönetiyoruz. Sunucu yönetimi kapsamında otomatik yedekleme, güvenlik yamaları ve performans optimizasyonu standart olarak dahildir. {local.area} için sunucu yönetimi teklifi almak ücretsizdir.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} Firewall Kurulumu ve Siber Güvenlik</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki firmalar için kurumsal firewall kurulumu yapıyoruz. Fortinet, Sophos ve pfSense tabanlı firewall kurulumu ile saldırı önleme (IPS/IDS), içerik filtreleme ve 5651 loglama hizmetleri sunuyoruz. Siber güvenlik kapsamında {local.area} bölgesindeki şirketlere ağ güvenliği değerlendirmesi, penetrasyon testi ve güvenlik politikası oluşturma desteği veriyoruz. Siber güvenlik tehditlerine karşı proaktif koruma yaklaşımımızla {local.area}'daki işletmelerin dijital varlıklarını koruyoruz.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} Network Kurulumu ve Kablolama</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'da ofis network kurulumu ve yapısal kablolama hizmetleri sunuyoruz. CAT6/CAT6A kablolama, yönetilebilir switch yapılandırması, kurumsal Wi-Fi kurulumu ve misafir ağı segmentasyonu ile {local.area} bölgesindeki iş yerlerinin ağ altyapısını profesyonel standartlarda kuruyoruz. Network kurulumu kapsamında {local.area}'daki firmalara Wi-Fi site survey, sinyal optimizasyonu ve QoS (trafik önceliklendirme) hizmeti de veriyoruz. Kopan bağlantı, yavaş internet ve Wi-Fi çekmeme sorunlarını network kurulumu ile kökünden çözüyoruz.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} Veri Yedekleme ve Felaket Kurtarma</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki işletmeler için veri yedekleme ve felaket kurtarma çözümleri sunuyoruz. 3-2-1 kuralına uygun veri yedekleme mimarisi (3 kopya, 2 farklı medya, 1 offsite) kuruyoruz. {local.area} bölgesindeki firmalar için otomatik yedekleme politikaları, bulut yedekleme (Azure, Wasabi), aylık geri yükleme testi ve yazılı felaket kurtarma planı (DRP) hazırlıyoruz. Veri yedekleme ve felaket kurtarma hizmetlerimiz KVKK uyumlu şifreleme standartlarına uygun çalışır. Fidye yazılımına karşı immutable backup katmanı da dahildir.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} Kurumsal E-Posta Kurulumu</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki şirketler için kurumsal e-posta kurulumu yapıyoruz. Microsoft 365 ve Google Workspace ile kurumsal e-posta kurulumu, mevcut sistemden veri kaybı olmadan e-posta taşıma (migrasyon) ve SPF/DKIM/DMARC güvenlik yapılandırması sunuyoruz. {local.area} bölgesindeki firmaların kurumsal e-posta altyapısını antispam ve antiphishing korumasıyla güçlendiriyoruz. Kurumsal e-posta kurulumu sonrası çalışan eğitimi ve teknik destek de hizmetimizin parçasıdır.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} VPN Kurulumu ve Uzaktan Erişim</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki firmalar için VPN kurulumu ve güvenli uzaktan erişim altyapısı kuruyoruz. IPsec, SSL VPN ve WireGuard protokolleriyle VPN kurulumu yaparak {local.area}'daki şirketlerin uzaktan çalışan ekiplerine güvenli bağlantı sağlıyoruz. Şube ofisleri arası site-to-site VPN kurulumu, merkez-şube bağlantısı ve zero-trust network access (ZTNA) çözümleri de hizmetlerimiz arasında. VPN kurulumu ile hibrit ve uzaktan çalışma modellerini {local.area}'daki işletmeler için güvenle destekliyoruz.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} IT Outsource — Yönetilen IT Hizmetleri</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki KOBİ ve orta ölçekli işletmelere IT outsource hizmeti sunuyoruz. IT outsource modelimizle tam zamanlı IT personeli istihdam etmeden profesyonel teknik destek alırsınız. {local.area} bölgesinde IT outsource kapsamında sunucu yönetimi, firewall yönetimi, network bakımı, yedekleme takibi, kullanıcı destek hattı ve aylık raporlama dahildir. IT outsource ile {local.area}'daki şirketler aylık sabit ücretle, sürpriz fatura olmadan, öngörülebilir bütçeyle IT altyapılarını yönettirir.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} Helpdesk ve Bilgisayar Destek</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki çalışanlarınız için helpdesk ve bilgisayar destek hattı sunuyoruz. Bilgisayar destek kapsamında şifre sıfırlama, yazılım kurulumu, yazıcı sorunu, Outlook çalışmıyor, internet yavaş, bilgisayar yavaş gibi günlük IT sorunlarını hızlıca çözüyoruz. {local.area} bölgesinde helpdesk hizmetimiz telefon, e-posta ve uzaktan bağlantı ile SLA garantili teknik destek sunar. Bilgisayar destek ve helpdesk hattımız {local.area}'daki firmalar için 7/24 teknik destek sağlar. Uzaktan çözülemeyen sorunlarda {local.area}'ya aynı gün yerinde teknik destek gönderilir.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} KVKK Uyumlu IT Altyapısı</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki firmalar için KVKK uyumlu IT altyapısı kuruyoruz. KVKK uyumlu veri saklama politikaları, şifreli yedekleme, erişim kontrolü ve log yönetimi ile {local.area} bölgesindeki işletmelerin yasal yükümlülüklerini karşılıyoruz. KVKK uyumlu altyapı kapsamında kişisel veri envanteri, erişim yetki matrisi, veri imha prosedürleri ve denetim hazırlığı desteği sunuyoruz. {local.area}'daki şirketlerin KVKK uyumlu IT altyapısına geçişini planlı ve adım adım gerçekleştiriyoruz.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} Active Directory ve Merkezi Kimlik Yönetimi</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki 10+ çalışanlı şirketler için Active Directory kurulumu ve merkezi kimlik yönetimi hizmeti sunuyoruz. Active Directory ile çalışanlarınız tek şifre ile tüm sistemlere erişir, yetkilendirme merkezi olarak yönetilir ve ayrılan personelin erişimi anında kapatılır. {local.area} bölgesindeki firmalar için Microsoft Entra ID (Azure AD) ile bulut tabanlı Active Directory çözümü de sunuyoruz. Active Directory kurulumu, Group Policy yönetimi, MFA (çok faktörlü doğrulama) ve SSO (tek oturum açma) hizmetlerimiz mevcuttur.</p>
                </div>

                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-xl font-bold text-white mb-3">{local.area} Antivirus ve Uç Nokta Güvenliği</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki işletmelere kurumsal antivirus ve uç nokta güvenliği (endpoint protection) çözümleri sunuyoruz. ESET, Kaspersky, Bitdefender ve Microsoft Defender for Business gibi kurumsal antivirus çözümlerini {local.area}'daki şirketlerin ihtiyaçlarına göre kuruyoruz. Antivirus yönetimi kapsamında merkezi konsol kurulumu, otomatik güncelleme politikaları, tehdit raporlama ve fidye yazılımı koruması dahildir. {local.area} bölgesinde antivirus ile birlikte e-posta güvenliği ve web filtreleme entegrasyonu da sağlıyoruz.</p>
                </div>
              </div>
            </section>

            <!-- Sık Sorulan Sorular -->
            <section class="mb-16">
              <h2 class="text-3xl font-bold text-white mb-8">{local.area} IT Desteği Hakkında Sık Sorulan Sorular</h2>
              <div class="space-y-4">
                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-lg font-semibold text-cyan-400 mb-2">{local.area}'da saha müdahalesi ne kadar sürede yapılır?</h3>
                  <p class="text-slate-300 leading-relaxed">Ofisimiz İçerenköy'deki Quick Tower'da bulunuyor. {local.area} bölgesine uzaktan teknik destek anında, yerinde saha müdahalesi ise genellikle aynı iş günü içinde gerçekleştirilir. SLA paketinize bağlı olarak kritik durumlarda 1 saat içinde saha müdahalesi başlatılır.</p>
                </div>
                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-lg font-semibold text-cyan-400 mb-2">{local.area}'da firewall kurulumu ne kadar sürer?</h3>
                  <p class="text-slate-300 leading-relaxed">{local.area}'daki standart bir KOBİ için firewall kurulumu (cihaz teslimi, konfigürasyon, kural setleri, VPN ve raporlama dahil) genellikle 1-3 iş günü içinde tamamlanır. Firewall kurulumu öncesinde ücretsiz keşif görüşmesinde mevcut ağ yapınız analiz edilir.</p>
                </div>
                <div class="p-6 bg-slate-900/40 border border-slate-800/60 rounded-2xl">
                  <h3 class="text-lg font-semibold text-cyan-400 mb-2">{local.area}'da IT outsource aylık ne kadar?</h3>
