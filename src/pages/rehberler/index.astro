---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../sections/Footer.jsx';
import StickyContactBar from '../../components/StickyContactBar.jsx';
import ConsentNotice from '../../components/ConsentNotice.jsx';
import WhatsAppButton from '../../components/WhatsAppButton.jsx';
import { breadcrumbSchema } from '../../lib/schema';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const troubleshootCount = allPosts.filter((p) => p.data.troubleshoot === true).length;
const bultenCount = allPosts.filter((p) => p.data.bulten === true).length;
const hikayeCount = allPosts.filter((p) => p.data.hikaye === true).length;
const blogCount = allPosts.length;

const schemas = [
  breadcrumbSchema([
    { label: 'Anasayfa', href: '/' },
    { label: 'Rehberler' },
  ]),
];
---

<Layout
  title="Rehberler — IT Troubleshoot, KOBİ IT, Siber Güvenlik"
  description="Kozyatağı Bilişim rehberleri: IT troubleshoot, sistem yönetimi, KOBİ bilişim, siber güvenlik, yönetilen IT hizmetleri. Saha deneyiminden gerçek çözümler."
  canonical="/rehberler/"
  schema={schemas}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6">

        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-8 max-w-5xl mx-auto">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <span class="text-slate-300">Rehberler</span>
            </li>
          </ol>
        </nav>

        <!-- Hero -->
        <div class="max-w-4xl mx-auto mb-14 text-center">
          <h1 class="text-3xl md:text-5xl font-bold mb-5">
            IT Rehberleri ve Troubleshoot Kataloğu
          </h1>
          <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
            Orta ölçekli Türk şirketlerinin IT ekipleri için; saha deneyiminden gerçek senaryolar, adım adım çözümler ve stratejik içerikler.
          </p>
        </div>

        <!-- Alt Bölümler -->
        <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">

          <a
            href="/rehberler/troubleshoot/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-amber-950/40 to-orange-950/30 border border-amber-800/40 hover:border-amber-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-amber-900/40 border border-amber-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-amber-400 transition-colors">Troubleshoot Kataloğu</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              Outlook, Teams, Active Directory, FortiGate, Veeam, VMware ve daha fazlası için hata kodu + çözüm rehberleri.
            </p>
            <div class="text-sm text-amber-400 font-semibold">
              {troubleshootCount}+ rehber →
            </div>
          </a>

          <a
            href="/blog/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-cyan-950/40 to-blue-950/30 border border-cyan-800/40 hover:border-cyan-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-cyan-900/40 border border-cyan-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-cyan-400 transition-colors">IT Blog</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              KOBİ IT altyapısı, siber güvenlik, bulut, yedekleme, Fortinet vs Sophos karşılaştırmaları ve derin analizler.
            </p>
            <div class="text-sm text-cyan-400 font-semibold">
              {blogCount}+ yazı →
            </div>
          </a>

          <a
            href="/ransomware-risk-testi/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-rose-950/40 to-red-950/30 border border-rose-800/40 hover:border-rose-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-rose-900/40 border border-rose-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-rose-400 transition-colors">Ransomware Risk Testi</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              15 soruda şirketinizin ransomware saldırısına karşı hazırlık seviyesini ölçün. Anında skor + eksik alanlar.
            </p>
            <div class="text-sm text-rose-400 font-semibold">
              Testi al →
            </div>
          </a>

          <a
            href="/kvkk-oz-denetim/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-teal-950/40 to-emerald-950/30 border border-teal-800/40 hover:border-teal-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-teal-900/40 border border-teal-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-teal-400 transition-colors">KVKK Öz-Denetim</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              25 maddelik interaktif KVKK uyum kontrol listesi. Skor + eksiklik listesi + cezai risk tahmini.
            </p>
            <div class="text-sm text-teal-400 font-semibold">
              Denetim yap →
            </div>
          </a>

          <a
            href="/sunucu-boyutlandirma-hesaplayici/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-violet-950/40 to-purple-950/30 border border-violet-800/40 hover:border-violet-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-violet-900/40 border border-violet-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-violet-400 transition-colors">Sunucu Hesaplayıcı</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              Kullanıcı sayısı + iş yüküne göre CPU/RAM/disk/IOPS önerisi + tahmini maliyet.
            </p>
            <div class="text-sm text-violet-400 font-semibold">
              Hesapla →
            </div>
          </a>

          <a
            href="/sozluk/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-fuchsia-950/40 to-pink-950/30 border border-fuchsia-800/40 hover:border-fuchsia-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-fuchsia-900/40 border border-fuchsia-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-fuchsia-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-fuchsia-400 transition-colors">IT Terimler Sözlüğü</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              100+ kurumsal IT ve siber güvenlik terimi Türkçe açıklamayla. Alfabetik, rehberlere bağlantılı.
            </p>
            <div class="text-sm text-fuchsia-400 font-semibold">
              Sözlüğe git →
            </div>
          </a>

          <a
            href="/hata-kodlari/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-yellow-950/40 to-amber-950/30 border border-yellow-800/40 hover:border-yellow-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-yellow-900/40 border border-yellow-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-yellow-400 transition-colors">Hata Kodu İndeksi</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              Aradığınız hata kodunu (0x80070643, 4625, KRB_AP_ERR vb.) arayın, doğrudan çözüm rehberine ulaşın.
            </p>
            <div class="text-sm text-yellow-400 font-semibold">
              Hata ara →
            </div>
          </a>

          <a
            href="/it-maliyet-hesaplayici/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-emerald-950/40 to-teal-950/30 border border-emerald-800/40 hover:border-emerald-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-emerald-900/40 border border-emerald-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-emerald-400 transition-colors">IT Maliyet Hesaplayıcı</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              50-250 kişilik şirket için tahmini yıllık IT bütçesi hesaplayıcısı. Lisans, sunucu, firewall, MSP dahil.
            </p>
            <div class="text-sm text-emerald-400 font-semibold">
              Hesapla →
            </div>
          </a>

          <a
            href="/bulten/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-red-950/40 to-orange-950/30 border border-red-800/40 hover:border-red-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-red-900/40 border border-red-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z M12 15.75h.007v.008H12v-.008z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-red-400 transition-colors">Bilinen Sorunlar Bülteni</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              Microsoft, Fortinet, VMware, Veeam son sürümlerindeki bilinen hatalar, geçici çözümler ve kalıcı düzeltmeler — Türkçe release health.
            </p>
            <div class="text-sm text-red-400 font-semibold">
              {bultenCount} bülten →
            </div>
          </a>

          <a
            href="/hikayeler/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-purple-950/40 to-fuchsia-950/30 border border-purple-800/40 hover:border-purple-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-purple-900/40 border border-purple-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-purple-400 transition-colors">Saha Hikayeleri</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              Gerçek Türk şirketlerinde yaşanan IT krizleri, saat saat anlatımı ve çıkarılan dersler. Anonim vaka analizleri.
            </p>
            <div class="text-sm text-purple-400 font-semibold">
              {hikayeCount} hikaye →
            </div>
          </a>

          <a
            href="/sektorler/"
            class="group p-8 rounded-3xl bg-gradient-to-br from-indigo-950/40 to-purple-950/30 border border-indigo-800/40 hover:border-indigo-600/60 transition-all hover:-translate-y-1"
          >
            <div class="w-14 h-14 rounded-2xl bg-indigo-900/40 border border-indigo-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-indigo-400 transition-colors">Sektörel IT Çözümleri</h2>
            <p class="text-slate-300 leading-relaxed mb-3">
              Muhasebe, hukuk, sağlık, üretim, reklam ajansı gibi sektörlere özel IT altyapı ve uyum rehberleri.
            </p>
            <div class="text-sm text-indigo-400 font-semibold">
              10 sektör →
            </div>
          </a>

        </div>

      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
