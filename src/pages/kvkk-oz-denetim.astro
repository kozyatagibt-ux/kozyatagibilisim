---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../sections/Footer.jsx';
import StickyContactBar from '../components/StickyContactBar.jsx';
import ConsentNotice from '../components/ConsentNotice.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import KVKKAuditTool from '../components/KVKKAuditTool.jsx';
import { breadcrumbSchema } from '../lib/schema';

const schemas = [
  breadcrumbSchema([
    { label: 'Anasayfa', href: '/' },
    { label: 'KVKK Öz-Denetim' },
  ]),
];
---

<Layout
  title="KVKK Uyum Öz-Denetim Aracı — Şirketinizin Uyum Skorunu Ölçün"
  description="25 maddelik interaktif KVKK uyum kontrol listesi. VERBİS kaydı, aydınlatma, teknik/idari tedbirler, ilgili kişi hakları. Anında skor ve aksiyon listesi."
  canonical="/kvkk-oz-denetim/"
  schema={schemas}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6">

        <nav aria-label="Breadcrumb" class="mb-8 max-w-5xl mx-auto">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <span class="text-slate-300">KVKK Öz-Denetim</span>
            </li>
          </ol>
        </nav>

        <!-- Hero -->
        <div class="max-w-3xl mx-auto mb-10 text-center">
          <h1 class="text-3xl md:text-5xl font-bold mb-5">
            KVKK Uyum Öz-Denetim Aracı
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed">
            Şirketinizin KVKK (6698 sayılı Kanun) yükümlülüklerine ne kadar uyduğunu kontrol edin. 25 kritik madde; IT altyapısı, prosedür ve belge bazlı. Anında skor, eksiklik listesi ve cezai risk tahmini.
          </p>
        </div>

        <!-- Tool -->
        <KVKKAuditTool client:load />

        <!-- Disclaimer -->
        <section class="max-w-3xl mx-auto mt-20">
          <div class="p-6 rounded-2xl bg-amber-900/20 border border-amber-800/40">
            <p class="text-sm text-amber-200 leading-relaxed">
              <strong class="text-amber-100">Önemli:</strong> Bu araç genel bir öz-değerlendirme sağlar ve hukuki danışmanlık yerine geçmez. KVKK Kanunu ve ikincil mevzuatın spesifik yorumu için avukat + IT danışmanı kombinasyonu ile tam denetim yaptırılmalıdır. Kozyatağı Bilişim olarak <strong>IT tarafındaki teknik ve idari tedbirleri</strong> kurmakta uzmanız; hukuki ayağı anlaşmalı avukat ağımızla beraber yürütüyoruz.
            </p>
          </div>
        </section>

        <!-- CTA -->
        <section class="max-w-3xl mx-auto mt-12 text-center">
          <div class="p-8 rounded-3xl bg-gradient-to-br from-blue-950/40 to-cyan-950/20 border border-blue-800/30">
            <h2 class="text-2xl font-bold mb-3">Skorunuz %80'in Altındaysa</h2>
            <p class="text-slate-400 mb-6">
              Eksikleri kapatmak için KVKK + IT sağlık kontrolü paketimiz ile başlangıç görüşmesi sunuyoruz. Öncelik sıralaması, maliyet tahmini ve 90 günlük yol haritası birlikte.
            </p>
            <a
              href="/#contact"
              class="inline-block px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-xl font-bold transition-all"
            >
              Ücretsiz Uyum Değerlendirmesi
            </a>
          </div>
        </section>

      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
