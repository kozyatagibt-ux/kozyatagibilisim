const COLOR_MAP: Record<string, string> = {
  'muhasebe-ofisi-it': 'text-emerald-400 border-emerald-800/60 bg-emerald-900/30',
  'hukuk-burosu-it': 'text-blue-400 border-blue-800/60 bg-blue-900/30',
  'saglik-klinik-it': 'text-rose-400 border-rose-800/60 bg-rose-900/30',
  'e-ticaret-it-altyapisi': 'text-violet-400 border-violet-800/60 bg-violet-900/30',
  'lojistik-depo-it': 'text-orange-400 border-orange-800/60 bg-orange-900/30',
  'egitim-kurumu-it': 'text-cyan-400 border-cyan-800/60 bg-cyan-900/30',
  'restoran-otel-it': 'text-amber-400 border-amber-800/60 bg-amber-900/30',
  'insaat-santiye-it': 'text-yellow-400 border-yellow-800/60 bg-yellow-900/30',
};
---

<Layout
  title="Sekt\u00f6rel IT \u00c7\u00f6z\u00fcmleri — Sekt\u00f6r\u00fcn\u00fcze \u00d6zel IT Altyap\u0131s\u0131"
  description="Muhasebe, hukuk, sa\u011fl\u0131k, e-ticaret, lojistik, e\u011fitim, restoran ve in\u015faat sekt\u00f6rlerine \u00f6zel IT altyap\u0131 \u00e7\u00f6z\u00fcmleri. Sekt\u00f6r\u00fcn\u00fcz\u00fc bilen IT orta\u011f\u0131."
  canonical="/sektorler"
  schema={[breadcrumbSchema([{ label: 'Anasayfa', href: '/' }, { label: 'Sekt\u00f6rler' }])]}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6">
        <nav aria-label="Breadcrumb" class="mb-6 max-w-5xl mx-auto">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <span class="text-slate-300">Sekt&ouml;rler</span>
            </li>
          </ol>
        </nav>

        <div class="text-center mb-20 max-w-3xl mx-auto">
          <div class="inline-block px-4 py-1 rounded-full bg-cyan-900/30 text-cyan-400 text-sm font-semibold mb-4 border border-cyan-800">
            SEKTÖREL ÇÖZÜMLER
          </div>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">
            Sektörünüze Özel IT Altyapısı
          </h1>
          <p class="text-slate-400 text-lg">
            Her sektörün kendine özgü yazılımları, uyumluluk gereksinimleri ve operasyonel öncelikleri vardır. Sektörünüzü bilen bir IT ortağıyla çalışın.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto mb-20">
          {sectors.map((s) => {
            const colorClasses = COLOR_MAP[s.slug] || 'text-cyan-400 border-cyan-800/60 bg-cyan-900/30';
            const [textColor] = colorClasses.split(' ');
            const iconPath = ICON_PATHS[s.icon] || ICON_PATHS.Calculator;
            return (
              <a
                href={`/sektorler/${s.slug}`}
                class="group p-6 rounded-2xl bg-slate-900/40 border border-slate-800/60 hover:bg-slate-800/60 hover:border-cyan-500/30 hover:shadow-[0_0_30px_-10px_rgba(8,145,178,0.3)] hover:-translate-y-1 transition-all duration-300 block"
              >
                <div class={`w-14 h-14 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 shadow-lg border ${colorClasses}`}>
                  <svg class={`w-7 h-7 ${textColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                  </svg>
                </div>
                <h2 class="text-lg font-bold mb-2 text-white group-hover:text-cyan-400 transition-colors">
                  {s.title}
                </h2>
                <p class="text-sm text-slate-400 mb-4 leading-relaxed line-clamp-3">
                  {s.heroDesc}
                </p>
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-cyan-400 group-hover:text-cyan-300 transition-colors">
                  Detaylar &rarr;
                </span>
              </a>
            );
          })}
        </div>

        <div class="text-center max-w-2xl mx-auto">
          <h2 class="text-2xl font-bold text-white mb-4">Sektörünüzü listede göremiyor musunuz?</h2>
          <p class="text-slate-400 mb-6">
            Yukarıdaki sektörler dışında da hizmet veriyoruz. Ücretsiz keşif görüşmesinde sektörünüze özel ihtiyaçları birlikte değerlendirelim.
          </p>
          <a
            href="/#contact"
            class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-xl font-bold text-lg shadow-[0_4px_20px_rgba(79,70,229,0.4)] transition-all hover:-translate-y-0.5"
          >
            Ücretsiz Keşif Al →
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
