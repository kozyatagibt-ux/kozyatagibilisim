---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../sections/Footer.jsx';
import StickyContactBar from '../../components/StickyContactBar.jsx';
import ConsentNotice from '../../components/ConsentNotice.jsx';
import WhatsAppButton from '../../components/WhatsAppButton.jsx';
import FAQAccordion from '../../components/FAQAccordion.jsx';
import { sectors } from '../../data/sectors';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return sectors.map((s) => {
    const related = (s.relatedBlogs || [])
      .map((slug: string) => allPosts.find((p) => (p.data.slug || p.id) === slug))
      .filter(Boolean);
    return {
      params: { slug: s.slug },
      props: { sector: s, relatedPosts: related },
    };
  });
}

const { sector, relatedPosts } = Astro.props;
const s = sector;

const schemas = [
  breadcrumbSchema([
    { label: 'Anasayfa', href: '/' },
    { label: 'Sektörler', href: '/sektorler' },
    { label: s.title },
  ]),
  faqSchema(s.faqs.map((f: { q: string; a: string }) => ({ q: f.q, a: f.a }))),
];
---

<Layout
  title={`${s.title} | Kozyatağı Bilişim`}
  description={s.meta}
  canonical={`/sektorler/${s.slug}`}
  schema={schemas}
>
  <Navbar client:load />
  <WhatsAppButton client:load />
  <StickyContactBar />
  <main class="pb-16 md:pb-0">
    <div class="pt-28 pb-24 bg-slate-950 text-white min-h-screen">
      <div class="container mx-auto px-6">

        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-8 max-w-4xl mx-auto">
          <ol class="flex items-center flex-wrap gap-1 text-sm text-slate-400">
            <li><a href="/" class="hover:text-cyan-400 transition-colors">Anasayfa</a></li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <a href="/sektorler" class="hover:text-cyan-400 transition-colors">Sektörler</a>
            </li>
            <li class="flex items-center gap-1">
              <span class="text-slate-600 mx-1">/</span>
              <span class="text-slate-300">{s.title}</span>
            </li>
          </ol>
        </nav>

        <!-- Hero -->
        <div class="max-w-4xl mx-auto mb-16">
          <h1 class="text-3xl md:text-5xl font-bold mb-6">{s.h1}</h1>
          <p class="text-lg text-slate-400 leading-relaxed max-w-3xl">{s.heroDesc}</p>
        </div>

        <!-- Pain Points -->
        <section class="max-w-5xl mx-auto mb-20">
          <h2 class="text-2xl md:text-3xl font-bold mb-8">Sektörünüzün IT Sorunlarını Biliyoruz</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {s.painPoints.map((p: { title: string; desc: string }) => (
              <div class="p-5 rounded-2xl bg-red-950/20 border border-red-900/30">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-8 h-8 rounded-lg bg-red-900/40 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z M12 15.75h.007v.008H12v-.008z" />
                    </svg>
                  </div>
                  <h3 class="font-bold text-white text-sm">{p.title}</h3>
                </div>
                <p class="text-sm text-slate-400 leading-relaxed">{p.desc}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Solutions -->
        <section class="max-w-5xl mx-auto mb-20">
          <h2 class="text-2xl md:text-3xl font-bold mb-8">Çözümlerimiz</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {s.solutions.map((sol: { title: string; desc: string }, i: number) => (
              <div class="p-6 rounded-2xl bg-slate-900/40 border border-slate-800/60 hover:border-cyan-500/30 transition-colors">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-xl bg-cyan-900/30 border border-cyan-800/60 flex items-center justify-center flex-shrink-0 text-cyan-400 font-bold text-sm">
                    {i + 1}
                  </div>
                  <div>
                    <h3 class="font-bold text-white mb-2">{sol.title}</h3>
                    <p class="text-sm text-slate-400 leading-relaxed">{sol.desc}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Tech Stack -->
        <section class="max-w-4xl mx-auto mb-20">
          <h2 class="text-2xl font-bold mb-6">Kullandığımız Teknolojiler</h2>
          <div class="flex flex-wrap gap-3">
            {s.techStack.map((tech: string) => (
              <span class="px-4 py-2 rounded-full bg-slate-800/60 border border-slate-700 text-sm text-slate-300 font-medium">
                {tech}
              </span>
            ))}
          </div>
        </section>

        <!-- FAQs -->
        <section class="max-w-3xl mx-auto mb-20">
          <h2 class="text-2xl md:text-3xl font-bold mb-8">{s.title} — Sıkça Sorulan Sorular</h2>
          <FAQAccordion items={s.faqs} client:visible />
        </section>

        <!-- Related Blog Posts -->
        {relatedPosts.length > 0 && (
          <section class="max-w-4xl mx-auto mb-20">
            <h2 class="text-2xl font-bold mb-6">İlgili Rehberler</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
              {relatedPosts.map((post: any) => (
                <a
                  href={`/blog/${post.data.slug || post.id}`}
                  class="p-5 rounded-2xl bg-slate-900/40 border border-slate-800/60 hover:border-cyan-500/30 hover:-translate-y-1 transition-all block group"
                >
                  <h3 class="font-bold text-white group-hover:text-cyan-400 transition-colors mb-2 text-sm">
                    {post.data.title}
                  </h3>
                  <p class="text-xs text-slate-500 line-clamp-2">{post.data.meta_description}</p>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- CTA -->
        <section class="max-w-3xl mx-auto text-center">
          <div class="p-10 rounded-3xl bg-gradient-to-br from-blue-950/40 to-cyan-950/20 border border-blue-800/30">
            <h2 class="text-2xl md:text-3xl font-bold mb-4">{s.ctaText}</h2>
            <p class="text-slate-400 mb-8">
              30 dakikalık ücretsiz keşif görüşmesinde sektörünüze özel IT ihtiyaçlarını birlikte değerlendirelim.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="/#contact"
                class="px-8 py-4 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-xl font-bold shadow-[0_4px_20px_rgba(79,70,229,0.4)] transition-all hover:-translate-y-0.5"
              >
                Ücretsiz Keşif Al
              </a>
              <a
                href="tel:+905416367775"
                class="px-8 py-4 bg-slate-800 hover:bg-slate-700 text-white rounded-xl font-bold border border-slate-700 transition-all"
              >
                0541 636 77 75
              </a>
            </div>
          </div>
        </section>

      </div>
    </div>
  </main>
  <Footer />
  <ConsentNotice client:idle />
</Layout>
