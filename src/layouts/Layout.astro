---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: string;
  schema?: object[];
  geoPlacename?: string;
}

const {
  title,
  description,
  canonical,
  noindex = false,
  ogType = 'website',
  schema = [],
  geoPlacename = 'İstanbul, Ataşehir',
} = Astro.props;

const SITE_URL = 'https://kozyatagibilisim.com';
const defaultTitle = 'Yönetilen IT Hizmetleri İstanbul | Kurumsal IT Desteği - Kozyatağı Bilişim';
// 150-160 karakter bandında tutuluyor (Google snippet limitine göre).
const defaultDescription = 'İstanbul kurumsal IT destek: sunucu, network, firewall, yedekleme, siber güvenlik. KOBİ ve orta ölçekli işletmeler için yönetilen IT hizmetleri.';

const finalTitle = title ? `${title} | Kozyatağı Bilişim` : defaultTitle;
const finalDescription = description || defaultDescription;
let finalCanonical = canonical || '/';
// Trailing slash tutarlılığı: canonical her zaman / ile bitmeli
if (!finalCanonical.endsWith('/')) finalCanonical += '/';
if (finalCanonical.startsWith('/')) finalCanonical = SITE_URL + finalCanonical;

const defaultSchema = [
  {
    "@type": "Organization",
    "@id": SITE_URL + "/#organization",
    "name": "Kozyatağı Bilişim",
    "url": SITE_URL + "/",
    "logo": { "@type": "ImageObject", "url": SITE_URL + "/favicon.svg", "width": 512, "height": 512 },
    "telephone": "+90 541 636 77 75",
    "email": "destek@kozyatagibilisim.com",
    "foundingDate": "2024",
    "numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 2, "maxValue": 10 },
    "sameAs": [
      "https://www.instagram.com/kozyatagibilisim",
      "https://www.linkedin.com/company/kozyatagibilisim",
      "https://g.co/kgs/kozyatagibilisim"
    ]
  },
  {
    "@type": "ProfessionalService",
    "@id": SITE_URL + "/#localbusiness",
    "name": "Kozyatağı Bilişim",
    "image": SITE_URL + "/og-image.jpg",
    "url": SITE_URL + "/",
    "telephone": "+90 541 636 77 75",
    "email": "destek@kozyatagibilisim.com",
    "priceRange": "₺₺",
    "description": "İstanbul merkezli kurumsal IT desteği, yönetilen IT hizmetleri, sunucu, network, firewall, yedekleme ve siber güvenlik çözümleri.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Quick Tower, İçerenköy E-5 Yanyolu, Umut Sk. No:8",
      "addressLocality": "Ataşehir",
      "addressRegion": "İstanbul",
      "postalCode": "34752",
      "addressCountry": "TR"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 40.9840, "longitude": 29.0970 },
    "areaServed": [
      { "@type": "City", "name": "İstanbul" },
      { "@type": "AdministrativeArea", "name": "Anadolu Yakası" }
    ],
    "openingHoursSpecification": [{
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "18:00"
    }],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Yönetilen IT Hizmetleri",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sunucu ve Sanallaştırma" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ağ Güvenliği ve Firewall" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Kurumsal E-Posta" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Yedekleme ve Felaket Kurtarma" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Network ve Altyapı Kurulumu" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Merkezi Kimlik Yönetimi" } }
      ]
    }
  },
  {
    "@type": "WebSite",
    "@id": SITE_URL + "/#website",
    "url": SITE_URL + "/",
    "name": "Kozyatağı Bilişim",
    "publisher": { "@id": SITE_URL + "/#organization" },
    "inLanguage": "tr-TR"
  }
];

const allSchema = [...defaultSchema, ...schema];

import '../index.css';
---

<!doctype html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0f172a" />

  <title>{finalTitle}</title>
  <meta name="description" content={finalDescription} />
  <meta name="author" content="Kozyatağı Bilişim" />
  <meta name="robots" content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
  <meta name="language" content="Turkish" />
  <meta name="geo.region" content="TR-34" />
  <meta name="geo.placename" content={geoPlacename} />

  <link rel="canonical" href={finalCanonical} />
  <link rel="alternate" type="application/rss+xml" title="Kozyatağı Bilişim Blog" href={`${SITE_URL}/rss.xml`} />
  <link rel="alternate" hreflang="tr" href={finalCanonical} />
  <link rel="alternate" hreflang="x-default" href={finalCanonical} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Kozyatağı Bilişim" />
  <meta property="og:locale" content="tr_TR" />
  <meta property="og:title" content={finalTitle} />
  <meta property="og:description" content={finalDescription} />
  <meta property="og:url" content={finalCanonical} />
  <meta property="og:image" content={`${SITE_URL}/og-image.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Kozyatağı Bilişim - Kurumsal IT Çözümleri" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={finalTitle} />
  <meta name="twitter:description" content={finalDescription} />
  <meta name="twitter:image" content={`${SITE_URL}/og-image.jpg`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://api.emailjs.com" />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Google tag (gtag.js) — GA4 + Google Ads -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18071896701"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-18071896701');
    /* GA4 G-G2B2C4JKS6 verisi AW- üzerinden akar (bağlı hesaplar) */
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": allSchema })} />
</head>
<body class="min-h-screen bg-slate-900 text-white font-sans selection:bg-cyan-500/30">
  <!-- gtag.js noscript fallback not needed -->
  <slot />
</body>
</html>
